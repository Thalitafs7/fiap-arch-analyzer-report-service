# ============================================================
# Variáveis de ambiente — copie para .env e preencha os valores
# ============================================================

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings RAG)
OPENAI_API_KEY=sk-...

# PostgreSQL
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=hackathon123
POSTGRES_DB=hackathon_db

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# SQS — URL da fila enviada pelo time SOAT
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/hackathon-queue

# App
LOG_LEVEL=INFO
