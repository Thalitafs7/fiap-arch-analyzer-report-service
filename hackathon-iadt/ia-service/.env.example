# ============================================================
# ia-service — variáveis de ambiente (copie para .env)
# ============================================================

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings text-embedding-3-small)
OPENAI_API_KEY=sk-...

# PostgreSQL + pgvector
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=hackathon123
POSTGRES_DB=hackathon_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Connection string para LangChain (psycopg driver)
POSTGRES_CONNECTION_STRING=postgresql+psycopg://hackathon:hackathon123@localhost:5432/hackathon_db

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
S3_BUCKET_NAME=hackathon-diagrams

# SQS
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/hackathon-queue

# ── Report Agent ─────────────────────────────────────────────────────────────
# Backend de geração de relatório:
#   "langchain"       → LangChain + LLM configurado abaixo (padrão)
#   "finetuned_api"   → LLM fine-tunado via HuggingFace Inference API
#   "finetuned_local" → LLM fine-tunado local (requer GPU no container)
REPORT_MODEL_BACKEND=langchain

# Modelo LLM usado pelo backend "langchain" (ex: claude-opus-4-6, gpt-4o, gemini-1.5-pro)
LLM_MODEL=claude-opus-4-6

# HuggingFace — necessário quando REPORT_MODEL_BACKEND=finetuned_api
HUGGINGFACE_API_TOKEN=hf_...
HUGGINGFACE_ENDPOINT_URL=https://api-inference.huggingface.co/models/seu-usuario/report-lora

# Modelo local — necessário quando REPORT_MODEL_BACKEND=finetuned_local
LOCAL_MODEL_PATH=./output/report-lora-adapter
BASE_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.3

# Aplicação
APP_ENV=development
LOG_LEVEL=INFO
